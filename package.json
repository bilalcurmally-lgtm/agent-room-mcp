{
  "name": "@billu/agent-room-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local file-backed MCP room for coordinating multiple coding agents across projects.",
  "bin": {
    "agent-room-mcp": "./dist/server.js",
    "agent-room-dashboard": "./dist/dashboard.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsx src/server.ts",
    "dashboard": "tsx src/dashboard.ts",
    "start-room": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-room.ps1",
    "install-shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-agent-room-shortcut.ps1",
    "install-suite": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-agent-room-suite.ps1",
    "watch-room": "node scripts/room-watch.mjs",
    "notify-room": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/notify-agent-room.ps1",
    "start-watch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-room-watch.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
